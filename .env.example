# Helvetic Reserve local development
NODE_ENV=development
PORT=3000
PUBLIC_CONTACT_EMAIL=contact@helvetic-reserve.com
PUBLIC_SITE_URL=http://127.0.0.1:3000

# Database
# Required in production. Use a managed PostgreSQL connection string.
DATABASE_URL=

# Optional local fallback. If DATABASE_URL is missing, the app tries this URL.
DEV_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/helvetic_reserve

# Optional Cloudflare Hyperdrive provisioning metadata.
# Hyperdrive points to an existing PostgreSQL origin; it does not create the DB.
# Keep CLOUDFLARE_API_TOKEN in your shell/secret manager only, not in git.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
HYPERDRIVE_CONFIG_ID=

# Authentication
# Required in production. Generate a long random value and configure it as a secret.
JWT_SECRET=

# Server-side admin password login. Store the hash, never the plaintext password.
# Generate with: $env:ADMIN_PASSWORD_PLAINTEXT="<password>"; corepack pnpm auth:hash-password
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Required in production for the existing Manus OAuth admin flow.
OWNER_OPEN_ID=
OAUTH_SERVER_URL=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Local preview only. Never enable in production.
LOCAL_ADMIN_BYPASS=0

# Cloudflare R2 media storage
# Optional locally because server/storage.ts falls back to client/public/uploads.
# Required for production uploads if you want R2-backed media.
# For EU jurisdiction buckets: https://<account_id>.eu.r2.cloudflarestorage.com
# For default jurisdiction buckets: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Admin URL importer
# No secret needed. The allowed supplier list is enforced in server/importer/allowedSuppliers.ts.
# Imported retailer images are copied to local uploads in dev or R2 when the R2 variables above are configured.

# Optional OpenAI extraction enhancer for the admin URL importer.
# Store the real key only in .env.local or production secrets, never in git.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2

# Supplier catalogue sync
# Redis is required only for scheduled BullMQ jobs. Manual admin sync can run inline in local dev.
REDIS_URL=redis://127.0.0.1:6379
SYNC_WORKER_ENABLED=0
SYNC_CRON_SECRET=
CATALOG_SYNC_ENABLED=0
RAW_SNAPSHOT_RETENTION_DAYS=30
AI_NORMALIZATION_ENABLED=0
AI_NORMALIZATION_MODEL=gpt-5.5
PRICE_CHANGE_REVIEW_THRESHOLD_PERCENT=25
MISSING_PRODUCT_DISABLE_THRESHOLD=3

# Cloudflare Email Service
# Email Routing handles inbound contact@ mail. Email Sending sends transactional/admin messages.
# Create CLOUDFLARE_EMAIL_API_TOKEN with Email Sending: Edit permission.
CLOUDFLARE_EMAIL_ROUTING_ADDRESS=contact@helvetic-reserve.com
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM=contact@helvetic-reserve.com
CLOUDFLARE_EMAIL_TO=contact@helvetic-reserve.com
# Sends customer confirmations too. Requires Cloudflare Email Sending entitlement for arbitrary recipients.
CLOUDFLARE_EMAIL_SEND_CUSTOMER_CONFIRMATION=0

# Crypto payments: BTCPay Server
# Free/self-hosted. XMR requires the BTCPay Monero plugin and Monero wallet/node setup.
BTCPAY_ENABLED=0
BTCPAY_SERVER_URL=
BTCPAY_STORE_ID=
BTCPAY_API_KEY=
BTCPAY_WEBHOOK_SECRET=
BTCPAY_DEFAULT_CURRENCY=CHF
